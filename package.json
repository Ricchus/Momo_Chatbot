{
  "name": "maomao-local-gif-chat",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "predev": "node scripts/generate-avatar-manifest.mjs",
    "dev": "vite",
    "prebuild": "node scripts/generate-avatar-manifest.mjs",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "retime:avatar": "node scripts/retime-avatar-gifs.mjs",
    "sync:avatar": "npm run retime:avatar && npm run gen:reverse && npm run gen:manifest",
    "validate:avatar": "node scripts/validate-avatar-gifs.mjs",
    "gen:manifest": "node scripts/generate-avatar-manifest.mjs",
    "gen:reverse": "node scripts/generate-reverse-gifs.mjs",
    "gen:avatar": "node scripts/generate-reverse-gifs.mjs && node scripts/generate-avatar-manifest.mjs",
    "preview:avatar:bg-match": "node scripts/preview-match-avatar-background.mjs"
  },
  "dependencies": {
    "gifuct-js": "^2.1.2",
    "openai": "^5.12.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.4",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.2"
  }
}
